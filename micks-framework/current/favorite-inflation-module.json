{
  "module": "favorite_inflation_and_failure_to_cover",
  "version": "2026-07-12",
  "status": "permanent",
  "applies_to": [
    "market_refresh",
    "card_grading",
    "writeups",
    "api_records",
    "website_releases",
    "parlays",
    "post_card_reviews"
  ],
  "principle": "Strong teams are not automatically strong bets. Separate outright-win probability from spread or run-line cover probability and account for market tax.",
  "required_windows": [5, 10, 20],
  "required_metrics": [
    "straight_up_record",
    "ats_or_run_line_record",
    "closing_number",
    "final_margin",
    "margin_vs_closing_expectation",
    "consecutive_non_covers",
    "favorite_cover_rate",
    "comparable_spread_band_record",
    "home_road_split",
    "rest_and_travel_context",
    "public_ticket_percentage",
    "handle_percentage",
    "opening_line",
    "closing_line",
    "non_covering_win_type",
    "brand_reputation_tax"
  ],
  "alert_levels": {
    "level_1_caution": {
      "minimum_conditions": 2,
      "conditions": [
        "failed_to_cover_3_of_last_5",
        "last_10_cover_rate_below_45_percent",
        "two_consecutive_non_covers_as_favorite",
        "average_margin_underperformance_at_least_1_5_points_or_0_5_runs",
        "public_tickets_above_70_percent_with_reverse_or_flat_line_move",
        "current_number_at_least_1_5_points_or_0_5_runs_worse_than_comparable_band"
      ],
      "actions": [
        "reduce_confidence",
        "prohibit_automatic_A_grade",
        "document_inflation_in_market_context",
        "evaluate_alternate_markets"
      ]
    },
    "level_2_strong_inflation": {
      "minimum_conditions": 1,
      "conditions": [
        "failed_to_cover_4_of_last_5",
        "failed_to_cover_6_of_last_8",
        "last_10_favorite_cover_rate_40_percent_or_lower",
        "three_or_more_consecutive_non_covers_while_still_winning_often",
        "average_margin_underperformance_at_least_3_points_or_0_75_runs",
        "closing_number_worsens_despite_repeated_non_covers",
        "lost_at_least_1_5_units_last_5_ats_or_run_line_bets"
      ],
      "grade_cap": "B",
      "unit_cap": 0.5,
      "actions": [
        "spread_or_run_line_not_vip_eligible",
        "exclude_inflated_market_from_parlays",
        "route_to_derivative_live_watchlist_or_pass"
      ]
    },
    "level_3_progressive_fade": {
      "minimum_conditions": 2,
      "conditions": [
        "failed_to_cover_5_of_last_6",
        "last_10_comparable_cover_rate_30_percent_or_lower",
        "four_consecutive_non_covers",
        "negative_ats_or_run_line_roi_at_least_20_percent_last_10",
        "repeated_wins_by_margins_materially_below_closing_requirement",
        "public_support_above_75_percent_while_number_inflates",
        "current_price_is_worst_recent_comparable_number_without_material_upgrade"
      ],
      "spread_or_run_line_action": "automatic_pass_unless_explicit_user_override",
      "derivative_grade_cap": "B-",
      "derivative_unit_cap": 0.25,
      "actions": [
        "exclude_from_lotto_parlays",
        "exclude_from_pick_of_the_day",
        "require_explicit_favorite_inflation_alert",
        "opponent_spread_requires_independent_matchup_validation"
      ]
    }
  },
  "automatic_adjustments": {
    "level_1": "reduce_half_grade_or_confidence_by_0_5_to_1_0",
    "level_2": "reduce_at_least_one_full_grade_and_cap_at_B_0_50u",
    "level_3": "spread_or_run_line_pass_and_derivative_cap_B_minus_0_25u"
  },
  "A_grade_favorite_requirements": [
    "no_level_2_or_level_3_alert",
    "meaningful_cover_rate_at_least_50_percent_or_documented_sample_break",
    "current_lineup_starter_role_or_matchup_upgrade_supports_margin",
    "current_number_not_worse_than_comparable_historical_band",
    "at_least_two_independent_cover_paths",
    "no_unresolved_public_tax_or_reverse_line_movement_concern"
  ],
  "alternate_market_order": [
    "moneyline_if_price_is_acceptable",
    "first_half_or_first_quarter",
    "first_to_10_or_first_to_15",
    "first_five_innings",
    "team_total_with_independent_support",
    "opponent_spread_with_independent_support",
    "live_entry_with_exact_trigger",
    "pass"
  ],
  "parlay_rules": [
    "level_2_or_level_3_spread_or_run_line_cannot_be_parlay_leg",
    "moneyline_allowed_only_with_strong_outright_profile_and_acceptable_combined_price",
    "do_not_stack_same_inflated_team_across_straight_derivative_and_parlay",
    "disclose_conversion_from_spread_or_run_line_to_moneyline",
    "do_not_pair_two_active_inflation_alert_teams_in_one_official_parlay"
  ],
  "writeup_requirements": [
    "recent_straight_up_performance",
    "recent_ats_or_run_line_performance",
    "whether_team_is_winning_without_covering",
    "current_number_vs_recent_comparable_numbers",
    "exact_alert_level",
    "grade_or_unit_deduction",
    "alternate_market_or_pass_reason",
    "pattern_reset_condition"
  ],
  "approved_label": "Favorite Inflation Alert: The team remains capable of winning outright, but its recent margin profile has not justified the market's spread or run-line tax.",
  "reset_conditions": [
    "covers_3_of_4_comparable_favorite_spots",
    "last_10_cover_rate_returns_above_50_percent",
    "average_margin_meets_or_exceeds_closing_requirement",
    "material_roster_injury_rotation_pitching_coaching_or_tactical_change_invalidates_sample",
    "market_materially_corrects_price",
    "current_matchup_has_demonstrably_different_margin_profile"
  ],
  "single_cover_does_not_reset_level_2_or_level_3": true,
  "initial_team_watchlist": {
    "New York Liberty": {
      "status": "monitored_not_automatic_fade",
      "restrictions_until_review": [
        "no_A_grade_spread",
        "no_spread_in_official_parlay",
        "moneyline_or_derivative_requires_price_validation"
      ]
    },
    "Los Angeles Dodgers": {
      "status": "monitored_not_automatic_fade",
      "restrictions_until_review": [
        "no_A_grade_run_line",
        "no_run_line_in_official_parlay",
        "moneyline_or_derivative_requires_price_validation"
      ]
    }
  },
  "publishing_validation": [
    "progressive_pattern_scan_completed",
    "alert_level_recorded_or_none",
    "straight_up_data_separated_from_cover_data",
    "grade_and_unit_adjustment_applied",
    "alternate_markets_evaluated",
    "parlay_restrictions_enforced",
    "writeup_explains_market_tax_and_failure_path",
    "line_inside_no_bet_cutoff",
    "no_unsupported_trend_statistics",
    "endpoint_preserves_alert_fields"
  ],
  "record_fields": [
    "Favorite Inflation Alert",
    "Inflation Alert Level",
    "Last 5 Cover Record",
    "Last 10 Cover Record",
    "Last 20 Cover Record",
    "Favorite Cover Rate",
    "Consecutive Non-Covers",
    "Average Margin vs Closing Line",
    "Comparable Spread Band Record",
    "Public Ticket Percentage",
    "Handle Percentage",
    "Opening Line",
    "Closing Line",
    "Inflation Grade Adjustment",
    "Inflation Unit Adjustment",
    "Alternate Market Reviewed",
    "Pattern Reset Condition"
  ],
  "governing_rule": "Protect the bankroll from repeatedly paying a premium for elite teams that win games but fail to beat the number. Team quality sets the baseline; price and cover probability determine whether the bet belongs on the card."
}