{
  "redirects": [
    { "source": "/vip", "destination": "/", "permanent": false },
    { "source": "/vip/", "destination": "/", "permanent": false },
    { "source": "/premium.html", "destination": "/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
